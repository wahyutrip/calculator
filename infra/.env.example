# Local Docker infrastructure settings. Copied to infra/.env by scripts/setup.sh
# (or scripts/infra.sh). Never commit infra/.env.
#
# Non-standard ports on purpose: sekar and swat run on 5432/8080 on the same
# development machine.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mm_dev
POSTGRES_PORT=5433

ADMINER_PORT=8081
