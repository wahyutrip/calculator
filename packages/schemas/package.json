{
  "name": "@mm/schemas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "@mm/calc": "workspace:*",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@mm/eslint-config": "workspace:*",
    "@mm/tsconfig": "workspace:*",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
