# Local development for the API. Copied to .env.local by scripts/setup.sh --with-be.
# Never commit .env.local.
#
# Phase 2 — the MVP calculator does not call this service.
#
# 3000 is the documented default; this checkout pins 4210 in .env.local to avoid
# sekar/swat, which already hold 3000 on the same machine.
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Must match infra/.env POSTGRES_PORT. scripts/setup.sh --with-be keeps these in
# sync for you (sync_backend_infra_ports).
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/mm_dev

# Explicit allow-list. Never "*" once auth exists.
CORS_ORIGIN=http://localhost:3001
