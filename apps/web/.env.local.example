# Local development for the web app. Copied to .env.local by scripts/setup.sh.
# Never commit .env.local.
#
# 3001 is the documented default. Your actual .env.local may pin something else
# (this checkout uses 4220) to avoid clashing with sekar/swat, which hold
# 3000/3001 on the same machine — the env file is always the source of truth and
# an exported WEB_PORT beats both.
WEB_PORT=3001

# Canonical URL for metadata, Open Graph and share links.
# NEXT_PUBLIC_* are inlined at BUILD time — changing this needs a rebuild, not a
# restart. Leave the port in sync with WEB_PORT.
NEXT_PUBLIC_APP_URL=http://localhost:3001
