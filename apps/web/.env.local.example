# Local development. Copied to .env.local by scripts/setup.sh — never commit .env.local.
#
# 3101 avoids 3000/3001, which sekar and swat already hold on this machine.
WEB_PORT=3101

# Canonical URL for metadata, Open Graph and share links.
# NEXT_PUBLIC_* are inlined at BUILD time — changing this needs a rebuild, not a restart.
NEXT_PUBLIC_APP_URL=http://localhost:3101
