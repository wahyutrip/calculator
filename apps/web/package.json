{
  "name": "@mm/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p ${WEB_PORT:-3101}",
    "dev:https": "next dev --experimental-https -p ${WEB_PORT:-3101}",
    "build": "next build",
    "start": "node scripts/serve-standalone.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "playwright test",
    "icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@mm/calc": "workspace:*",
    "@mm/schemas": "workspace:*",
    "@mm/ui": "workspace:*",
    "next": "^15.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@mm/eslint-config": "workspace:*",
    "@mm/tsconfig": "workspace:*",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4.1.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
