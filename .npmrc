# pnpm configuration for the money-management monorepo.
# Prisma is hoisted to the root node_modules so the generated client and the CLI
# resolve identically from apps/be and from root scripts (pnpm does not hoist by
# default, and Prisma's generated client resolves relative to its own package).
public-hoist-pattern[]=*prisma*
public-hoist-pattern[]=*@prisma*
auto-install-peers=true
strict-peer-dependencies=false
dedupe-peer-dependents=true
